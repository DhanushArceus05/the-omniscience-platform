# =====================================================================
# The Omniscience Platform — Environment Variables
# (Phase 0: Foundation + Phase 2: Authentication & Users, Step 1)
# Copy this file to .env and fill in real values. Never commit .env.
# =====================================================================

# ---------- Global ----------
NODE_ENV=development
LOG_LEVEL=info

# ---------- apps/web (React + Vite) ----------
VITE_APP_NAME="The Omniscience Platform"
VITE_API_BASE_URL=http://localhost:4000
# Optional. apps/ai-service is not part of this phase yet — leave unset so
# the frontend shows "AI Service: Not Configured" instead of polling a
# service that isn't running. Set this once apps/ai-service actually exists.
# VITE_AI_SERVICE_BASE_URL=http://localhost:8000

# ---------- apps/api (NestJS) ----------
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173

# ---------- apps/ai-service (FastAPI) ----------
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omniscience
POSTGRES_USER=omniscience
POSTGRES_PASSWORD=changeme
POSTGRES_URL=postgresql://omniscience:changeme@localhost:5432/omniscience

# ---------- MongoDB ----------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=omniscience
MONGO_USER=omniscience
MONGO_PASSWORD=changeme
MONGO_URL=mongodb://omniscience:changeme@localhost:27017/omniscience?authSource=admin

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ---------- Qdrant (Vector DB) ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# ---------- Phase 2 — JWT (access/refresh tokens) ----------
# Required. Generate strong random secrets, e.g.: openssl rand -hex 32
# Never reuse the same secret for access and refresh, never commit real values.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Optional — defaults match the approved Phase 2 decision.
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ---------- Phase 2 — SMTP (OTP / transactional email) ----------
# Optional as a whole, but all-or-nothing: if SMTP_HOST is set, every other
# SMTP_* variable below becomes required (validated in packages/config).
# Leave every SMTP_* variable blank/unset in development to have the API log
# the OTP code to the server console instead of sending an email.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="The Omniscience Platform <noreply@example.com>"
# SMTP_SECURE=false

# ---------- Phase 2 — OTP (registration / verification) ----------
# Optional — defaults match the approved Phase 2 decision.
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ---------- Phase 3 Step 3 — Avatar storage ----------
# MVP strategy: local disk, served back out by the API itself as static
# files (no existing pluggable object-storage abstraction to reuse — this
# is deliberately the first one, kept small/swappable behind
# AvatarStorageService, not a permanent architecture decision).
# Optional — defaults shown below are used if unset.
AVATAR_STORAGE_DIR=./storage/avatars
AVATAR_PUBLIC_BASE_URL=http://localhost:4000
AVATAR_MAX_UPLOAD_BYTES=5242880

# ---------- Phase 4 Step 1 — OmniProvider credentials ----------
# All optional and independent (no all-or-nothing rule, unlike SMTP): a
# provider whose key is left unset simply reports as "not-configured" via
# GET /ai/providers rather than blocking API startup.
# - ANTHROPIC_API_KEY: real execution since Phase 4 Step 2.
# - GEMINI_API_KEY: real execution since Phase 4 Step 4.
# - OPENAI_API_KEY: still a Step 1 metadata-only stub — setting it changes
#   configStatus() to "configured" but never enables real execution (see
#   OpenAiProvider/StubProviderDescriptor and the execution-eligibility
#   guard in ModelSelectorService).
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---------- Phase 4 Step 2 — Anthropic execution (timeout & retry) ----------
# ---------- Phase 4 Step 4 — Gemini execution (timeout only, see below) -----
# AI_REQUEST_TIMEOUT_MS is passed into both the official @anthropic-ai/sdk
# client's own `timeout` option (apps/api/src/ai/providers/anthropic-client.
# provider.ts) and the official @google/genai client's own
# `httpOptions.timeout` option (apps/api/src/ai/providers/gemini-client.
# provider.ts) — one shared timeout value for every real provider adapter.
#
# AI_MAX_RETRIES is passed into @anthropic-ai/sdk's own `maxRetries` option
# only. It is deliberately NOT applied to Gemini's client: a real local run
# showed that configuring @google/genai's `httpOptions.retryOptions` makes
# that SDK route every request through its bundled `p-retry` dependency,
# which discards the HTTP status/response body needed to classify errors
# correctly (e.g. an invalid API key was misclassified as a generic
# "provider unavailable" instead of an auth failure) — see
# gemini-client.provider.ts and gemini-error-mapper.ts for the full trace.
# Gemini therefore makes a single attempt per request today; an external,
# status-aware retry loop that doesn't depend on that SDK's own retry
# implementation is a deferred item. There is no custom retry/backoff loop
# anywhere in this codebase for Anthropic — its SDK's own retry behavior is
# the single source of truth there. Optional — defaults shown below are used
# if unset.
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=2

# ---------- Reserved for future phases (do not use yet) ----------
# OBJECT_STORAGE_ENDPOINT=
# OBJECT_STORAGE_BUCKET=
