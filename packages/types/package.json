{
  "name": "@omniscience/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types used across apps. Dual CJS/ESM build (consumed by both the NestJS API and the Vite web app).",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.cjs.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  }
}
