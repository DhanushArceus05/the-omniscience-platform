{
  "name": "@omniscience/api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS API — Phase 0 Foundation + Phase 2 Authentication & Users (Step 3 of 8 in progress).",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/throttler": "^6.2.1",
    "@omniscience/config": "workspace:*",
    "@omniscience/schemas": "workspace:*",
    "@omniscience/types": "workspace:*",
    "@omniscience/utils": "workspace:*",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.15",
    "pino": "^9.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.2",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
