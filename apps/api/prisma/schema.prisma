// The Omniscience Platform — apps/api Prisma schema
//
// Phase 2 (Authentication & Users) — Step 1: configuration foundation only.
// This file intentionally defines no models yet. Data models (starting
// with User) are introduced in Phase 2 Step 2 per the approved
// step-by-step plan, so that Step 1 can be reviewed and verified purely
// as configuration before any schema decisions are locked in.
//
// IMPORTANT: `prisma generate` and `prisma migrate` both require at least
// one model and will exit non-zero against this file as-is — that is
// expected Prisma CLI behavior, not a bug. Do not run `db:generate` /
// `db:migrate` (apps/api/package.json) until Step 2 adds the User model;
// Step 1's verification commands intentionally do not include them (see
// claude/CURRENT_PHASE.md). `PrismaService`/`PrismaModule` are likewise
// deferred to Step 2 for the same reason — they cannot be built against
// an ungenerated `@prisma/client`.
//
// The datasource intentionally reuses POSTGRES_URL (not a separate
// DATABASE_URL) to keep a single source of truth for the Postgres
// connection string, consistent with docs/05_Database_Design.md and the
// existing packages/config env schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}
