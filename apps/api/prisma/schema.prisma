// The Omniscience Platform — apps/api Prisma schema
//
// Phase 2 (Authentication & Users) — Step 2: first real model.
//
// The datasource intentionally reuses POSTGRES_URL (not a separate
// DATABASE_URL) to keep a single source of truth for the Postgres
// connection string, consistent with docs/05_Database_Design.md and the
// existing packages/config env schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

/// Authentication foundation user record (Phase 2 Step 2).
///
/// - `id` uses Prisma's `cuid()` (string, not an auto-incrementing
///   integer) per docs/05_Database_Design.md's "UUIDs" rule — cuid is a
///   URL-safe, sortable, collision-resistant string ID in the same
///   family as UUIDs.
/// - `email` is normalized (trimmed + lowercased) at the application
///   layer before every write, via the shared `emailSchema` in
///   `@omniscience/schemas`, so a plain case-sensitive unique index is
///   sufficient without a Postgres extension (e.g. `citext`).
/// - `name` mirrors the "Full name" field already present on the Phase 1
///   RegisterPage UI.
/// - `emailVerifiedAt` is null until the Step 3 OTP verification flow
///   sets it; its presence (not a boolean) also records *when*
///   verification happened.
/// - No OTP, refresh-token, workspace, billing, or profile fields here —
///   those are out of Step 2's approved scope (OTP/refresh tokens live
///   in Redis per the Phase 2 decisions, not Postgres).
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("users")
}
